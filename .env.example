# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth / roles
ALLOWED_EMAIL_DOMAIN=iimk.ac.in
# Comma-separated emails granted the admin role on first sign-in
ADMIN_EMAILS=you@iimk.ac.in

# Google OAuth (for sheet access + optional sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://yourapp.vercel.app/api/admin/oauth/callback

# Google Sheet
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_REFRESH_TOKEN=fill_after_admin_auth_step

# Cron security
CRON_SECRET=generate_a_random_secret_here

# Web Push (VAPID) - generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# App URL
NEXT_PUBLIC_APP_URL=https://yourapp.vercel.app
