# ── Required ──────────────────────────────────────────────────────────────────
# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth / roles
ALLOWED_EMAIL_DOMAIN=iimk.ac.in
# Comma-separated emails granted the admin role on first sign-in
ADMIN_EMAILS=you@iimk.ac.in

# Cron security (bearer for the scheduled jobs)
CRON_SECRET=generate_a_random_secret_here

# App URL
NEXT_PUBLIC_APP_URL=https://yourapp.vercel.app

# ── Optional ──────────────────────────────────────────────────────────────────
# Retention window in days for the purge cron (defaults to 180)
# RETENTION_DAYS=180

# Web Push (VAPID) — OPTIONAL. Without these the app runs fine; push notifications
# are simply disabled (the settings toggle is hidden). Generate with:
#   npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_EMAIL=mailto:your@email.com

# ── Google: NOT configured via env ──────────────────────────────────────────────
# Sheet reading is configured at RUNTIME, not here:
#   • The app's Google OAuth client (client_id/secret/redirect) lives once in the
#     Supabase `google_integration` row (migration 019), set at handover.
#   • An admin authorizes Google Sheets access once at sign-in; the refresh token is
#     stored server-side in that same row — never in env.
#   • The per-term sheet id is pasted as a link in Admin → Schedule (`schedule_sources`).
# For LOCAL DEV only, you may instead drop the client + token into env as a fallback:
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://yourapp.vercel.app/api/admin/oauth/callback
# GOOGLE_REFRESH_TOKEN=fill_after_admin_auth_step
